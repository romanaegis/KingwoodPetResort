{
  "api": {
    "blogapi": {
      "dependsOn": [
        {
          "attributes": [
            "Name",
            "Arn"
          ],
          "category": "function",
          "resourceName": "blogFunction"
        }
      ],
      "providerPlugin": "awscloudformation",
      "service": "API Gateway"
    }
  },
  "function": {
    "blogFunction": {
      "build": true,
      "dependsOn": [
        {
          "attributes": [
            "Name",
            "Arn",
            "StreamArn"
          ],
          "category": "storage",
          "resourceName": "blogTable"
        }
      ],
      "providerPlugin": "awscloudformation",
      "service": "Lambda"
    }
  },
  "parameters": {
    "AMPLIFY_function_blogFunction_blogApiSecret": {
      "usedBy": [
        {
          "category": "function",
          "resourceName": "blogFunction"
        }
      ]
    },
    "AMPLIFY_function_blogFunction_deploymentBucketName": {
      "usedBy": [
        {
          "category": "function",
          "resourceName": "blogFunction"
        }
      ]
    },
    "AMPLIFY_function_blogFunction_s3Key": {
      "usedBy": [
        {
          "category": "function",
          "resourceName": "blogFunction"
        }
      ]
    }
  },
  "storage": {
    "blogTable": {
      "providerPlugin": "awscloudformation",
      "service": "DynamoDB"
    }
  }
}